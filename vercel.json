{
  "version": 2,
  "services": {
    "frontend": {
      "root": "frontend"
    },
    "backend": {
      "root": "backend",
      "entrypoint": "main.py"
    }
  },
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": { "service": "backend", "path": "/api/:path*" }
    },
    {
      "source": "/:path*",
      "destination": { "service": "frontend", "path": "/:path*" }
    }
  ]
}
